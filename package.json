{
  "name": "careerdeck",
  "version": "0.14.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "e2e:server": "tsx scripts/e2e-server.ts",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project chromium",
    "test:e2e:firefox": "playwright test --project firefox",
    "test:e2e:webkit": "playwright test --project webkit",
    "test:e2e:live": "playwright test -c playwright.live.config.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "db:cleanup:e2e": "tsx scripts/cleanup-e2e-data.ts",
    "db:cleanup:e2e:public": "pnpm run db:cleanup:e2e -- --allow-public-schema",
    "db:cleanup:e2e:public:apply": "pnpm run db:cleanup:e2e -- --allow-public-schema --apply",
    "verify": "pnpm lint && pnpm typecheck && pnpm build && pnpm test:e2e"
  },
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "@prisma/adapter-pg": "7.7.0",
    "@prisma/client": "7.7.0",
    "bcryptjs": "3.0.3",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.7.0",
    "motion": "12.38.0",
    "next": "16.2.3",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "0.4.6",
    "pg": "8.20.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "server-only": "0.0.1",
    "shadcn": "4.1.2",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.2",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "^20",
    "@types/pg": "8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "prisma": "7.7.0",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": "1.19.13",
      "hono": "4.12.12"
    }
  }
}
